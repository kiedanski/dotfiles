#!/usr/bin/env bash
# getmusic [--no-tag] [--album "NAME"] [--playlist "NAME"] [--no-playlist] URL [URL...]
#
# Download audio into /card/music as MP3, tag it from MusicBrainz (whole-album
# match, with per-song fallback), save an MPD playlist of what was downloaded,
# and refresh MPD. Always MP3 (`--audio-quality 0` = highest VBR) with
# shell-friendly names (`--restrict-filenames`), embedding cover art + metadata.
# Works with YouTube, Bandcamp, SoundCloud, playlists, etc. A download-archive
# skips anything already grabbed.
#
#   --album "NAME"     tag against this exact album (most reliable).
#   --no-tag           just download; skip MusicBrainz tagging.
#   --playlist "NAME"  save one MPD playlist NAME with everything downloaded
#                      (default: one playlist per album, named after the album).
#   --no-playlist      don't create any playlist.
set -euo pipefail

dest="/card/music"
plist_dir="$HOME/.config/mpd/playlists"
no_tag=0
no_playlist=0
album=""
playlist=""
urls=()
while [ "$#" -gt 0 ]; do
	case "$1" in
		--no-tag)      no_tag=1; shift ;;
		--no-playlist) no_playlist=1; shift ;;
		--album)       album="${2:-}"; shift 2 ;;
		--album=*)     album="${1#--album=}"; shift ;;
		--playlist)    playlist="${2:-}"; shift 2 ;;
		--playlist=*)  playlist="${1#--playlist=}"; shift ;;
		--)            shift; while [ "$#" -gt 0 ]; do urls+=("$1"); shift; done ;;
		*)             urls+=("$1"); shift ;;
	esac
done

if [ "${#urls[@]}" -eq 0 ]; then
	echo "usage: getmusic [--no-tag] [--album \"NAME\"] [--playlist \"NAME\"] [--no-playlist] <url> [url...]" >&2
	exit 1
fi

mkdir -p "$dest"

# Snapshot the library so we can tell what's new (before download).
before=$(mktemp)
find "$dest" -type f -name '*.mp3' 2>/dev/null | sort > "$before"

yt-dlp \
	--extract-audio --audio-format mp3 --audio-quality 0 \
	--embed-thumbnail --embed-metadata --embed-chapters \
	--restrict-filenames \
	--download-archive "$dest/.archive" \
	--output "$dest/%(artist,uploader)s/%(title)s.%(ext)s" \
	"${urls[@]}"

# Folders that received new files (download locations, before tagging moves them).
after=$(mktemp)
find "$dest" -type f -name '*.mp3' 2>/dev/null | sort > "$after"
mapfile -t newdirs < <(comm -13 "$before" "$after" | xargs -r -d '\n' -n1 dirname | sort -u)
rm -f "$after"

# Auto-tag each new folder from MusicBrainz. Hybrid: whole-album match first
# (accurate, consistent track numbers), per-song fallback for singles / mixed
# playlists / partial downloads so everything still gets tagged.
if [ "$no_tag" -eq 0 ] && [ "${#newdirs[@]}" -gt 0 ] && command -v tag-album >/dev/null 2>&1; then
	for d in "${newdirs[@]}"; do
		echo "── tagging: $d"
		if [ -n "$album" ]; then
			tag-album "$d" "$album" --write || echo "   (album tag failed for $d)"
		elif tag-album "$d" --auto --write; then
			:   # matched as a single album — done
		else
			echo "   not one album → per-song tagging…"
			tag-songs "$d" --write || echo "   (per-song tagging had trouble for $d)"
		fi
	done
fi

command -v mpc >/dev/null 2>&1 && mpc update >/dev/null 2>&1 || true

# Save an MPD playlist of what was downloaded (at final, post-tagging locations).
if [ "$no_playlist" -eq 0 ]; then
	mkdir -p "$plist_dir"
	final=$(mktemp)
	find "$dest" -type f -name '*.mp3' 2>/dev/null | sort > "$final"
	mapfile -t newfiles < <(comm -13 "$before" "$final")
	rm -f "$final"
	if [ "${#newfiles[@]}" -gt 0 ]; then
		if [ -n "$playlist" ]; then
			# one named playlist containing everything downloaded this run
			name=$(printf '%s' "$playlist" | tr ' ' '_' | tr -cd 'A-Za-z0-9._-')
			[ -n "$name" ] || name="playlist"
			printf '%s\n' "${newfiles[@]}" | sed "s#^${dest}/##" | sort > "$plist_dir/$name.m3u"
			echo "♪ playlist: $name ($(wc -l < "$plist_dir/$name.m3u") tracks)"
		else
			# one playlist per album folder that got new tracks (= its full contents)
			printf '%s\n' "${newfiles[@]}" | xargs -r -d '\n' -n1 dirname | sort -u | while IFS= read -r d; do
				name=$(basename "$d")
				find "$d" -maxdepth 1 -type f -name '*.mp3' | sed "s#^${dest}/##" | sort > "$plist_dir/$name.m3u"
				echo "♪ playlist: $name ($(wc -l < "$plist_dir/$name.m3u") tracks)"
			done
		fi
	fi
fi

rm -f "$before"
echo "Done → $dest"
