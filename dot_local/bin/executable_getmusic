#!/usr/bin/env bash
# getmusic URL [URL...] — download audio into /card/music as MP3, tag it, refresh MPD.
#
# Always re-encodes to MP3 (`--audio-quality 0` = highest VBR) for maximum device
# compatibility, and embeds cover art + metadata. Filenames are shell-friendly
# (`--restrict-filenames`: ASCII only, spaces -> underscores, no ()/&/' etc.),
# for both the artist folder and the track name. Works with YouTube, Bandcamp,
# SoundCloud, playlists, etc. (anything yt-dlp supports). A download-archive skips
# anything already grabbed, so re-running a playlist URL only fetches new tracks.
set -euo pipefail

dest="/card/music"

if [ "$#" -eq 0 ]; then
	echo "usage: getmusic <url> [url...]" >&2
	exit 1
fi

mkdir -p "$dest"

yt-dlp \
	--extract-audio --audio-format mp3 --audio-quality 0 \
	--embed-thumbnail --embed-metadata --embed-chapters \
	--restrict-filenames \
	--download-archive "$dest/.archive" \
	--output "$dest/%(artist,uploader)s/%(title)s.%(ext)s" \
	"$@"

# Nudge MPD to index the new files (auto_update usually already caught them).
if command -v mpc >/dev/null 2>&1; then
	mpc update >/dev/null 2>&1 || true
fi

echo "Done → $dest"
