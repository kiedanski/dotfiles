{{- $name := promptStringOnce . "name" "Full name" "Diego Kiedanski" -}}
{{- $email := promptStringOnce . "email" "Email address" "diego@runllama.ai" -}}
{{- $desktop := promptBoolOnce . "desktop" "Is this a desktop/GUI machine" true -}}
{{- $tiling_wm := false -}}
{{- if $desktop -}}
{{-   $tiling_wm = promptBoolOnce . "tiling_wm" "Use tiling WM (bspwm/sxhkd/polybar)" false -}}
{{- end -}}
{{- $op_vault := promptStringOnce . "op_vault" "1Password vault for chezmoi secrets" "Chezmoi" -}}
{{- $tilde_host := promptStringOnce . "tilde_host" "CalDAV/CardDAV host for calendars and contacts" "dav.example.com" -}}

git:
  autoCommit: true
  autoPush: true

# `op signin` cannot create a classic session here (the CLI works only via the
# desktop-app integration), so a prompting apply blocks forever waiting for a
# sign-in that never comes. This lives in the generated config too — without it
# here, `chezmoi init` regenerates chezmoi.yaml without it and apply breaks.
onepassword:
  prompt: false

data:
  name: {{ $name | quote }}
  email: {{ $email | quote }}
  desktop: {{ $desktop }}
  tiling_wm: {{ $tiling_wm }}
  op_vault: {{ $op_vault | quote }}
  tilde_host: {{ $tilde_host | quote }}
