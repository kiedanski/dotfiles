[colors]
background = #282a36
background-alt = #44475a
foreground = #f8f8f2
primary = #bd93f9
secondary = #8be9fd
alert = #ff5555
success = #50fa7b

{{- /* The tablet is a ~220 DPI 10.5" panel. A 24px bar with size=10 fonts is
       unreadable and untappable there; other machines keep the original sizing. */ -}}
{{- $model := output "sh" "-c" "cat /sys/class/dmi/id/product_name 2>/dev/null || echo unknown" | trim }}
{{- $tablet := eq $model "Surface Go 2" }}
[bar/main]
monitor = ${env:MONITOR:}
width = 100%
height = {{ if $tablet }}44{{ else }}24{{ end }}
radius = 0
fixed-center = true

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 2
border-size = 0
padding-left = 1
padding-right = 1
module-margin = 1

{{- $fs := 10 }}{{ if $tablet }}{{ $fs = 13 }}{{ end }}
font-0 = "JetBrainsMono Nerd Font:size={{ $fs }};3"
; The old "FontAwesome" family is Font Awesome 4 and does not exist on current
; systems — fontconfig silently fell back to Noto Sans, so icons never rendered.
font-1 = "Font Awesome 7 Free:size={{ $fs }};3"
font-2 = "Font Awesome 7 Free Solid:size={{ $fs }};3"
font-3 = "Noto Color Emoji:style=Regular:scale=10;3"

{{- /* Tablet gets a tappable launcher button ahead of the desktop list.
       xwindow (the focused window's title) is dropped on the tablet: at up to 60
       characters it pushed the right-hand group off a 1920px bar and clipped the
       clock. The title bar of the window already says what the window is. */}}
modules-left = {{ if $tablet }}launcher {{ end }}bspwm{{ if not $tablet }} xwindow{{ end }}
modules-center = 
{{- /* The tablet gets a tappable on-screen-keyboard button; other machines don't need one. */}}
modules-right = {{ if $tablet }}osk {{ end }}filesystem memory cpu pulseaudio wlan battery powerdraw date


cursor-click = pointer
cursor-scroll = ns-resize

[module/bspwm]
type = internal/bspwm
pin-workspaces = true

label-focused = %name%
label-focused-background = ${colors.primary}
label-focused-foreground = ${colors.background}
label-focused-padding = 2

label-occupied = %name%
label-occupied-padding = 2
label-occupied-foreground = ${colors.secondary}

label-urgent = %name%!
label-urgent-background = ${colors.alert}
label-urgent-padding = 2

label-empty = %name%
label-empty-foreground = ${colors.background-alt}
label-empty-padding = 2

[module/xwindow]
type = internal/xwindow
label = %title:0:60:...%
label-foreground = ${colors.primary}

[module/filesystem]
type = internal/fs
interval = 25
mount-0 = /
label-mounted = 💾 %percentage_used%%
label-unmounted = %mountpoint% not mounted

[module/memory]
type = internal/memory
interval = 2
format-prefix = "🧠 "
label = %percentage_used%%

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "⚡ "
label = %percentage%%

[module/date]
type = internal/date
interval = 5
; Weekday is back: dropping the xwindow title freed plenty of width.
date = %a %b %d
time = %H:%M
label = 📅 %date% %time%

[module/pulseaudio]
type = internal/pulseaudio
format-volume = <label-volume>
label-volume = 🔊 %percentage%%
label-muted = 🔇 muted
label-muted-foreground = ${colors.background-alt}
click-right = pavucontrol

[module/launcher]
; Tap target for the launcher, shown ONLY in tablet mode: with a Type Cover
; attached `super + d` does the job and the button is just clutter. The script
; prints nothing when a keyboard is present, which collapses the module away.
type = custom/script
exec = ~/.local/bin/polybar-launcher
interval = 5
format-foreground = ${colors.primary}
format-padding = 2
click-left = rofi -show drun
click-right = rofi -show window

[module/osk]
; Tap target for the on-screen keyboard. The hyper+k binding and the 4-finger
; gesture both exist, but a hotkey is useless with no keyboard attached and a
; gesture is undiscoverable — a visible button on the bar is the reliable way in.
; A script, not custom/text, so it can hide itself when a Type Cover is
; attached — same as the launcher. Also drops the deprecated `content` key.
type = custom/script
exec = ~/.local/bin/polybar-osk
interval = 5
format-padding = 2
format-foreground = ${colors.primary}
click-left = osk-toggle

[module/wlan]
type = internal/network
; interface-type=wireless lets polybar find the wireless device itself, so this
; works on machines whose interface isn't called wlan0.
interface-type = wireless
interval = 5
format-connected = <label-connected>
format-disconnected = <label-disconnected>
; Room for the full SSID now that the xwindow title module is gone; only
; absurdly long names get cut.
label-connected = 📶 %essid:0:24:…%
label-disconnected = 📶 offline
label-disconnected-foreground = ${colors.background-alt}

[module/powerdraw]
type = custom/script
; The old inline awk hardcoded BAT0 + power_now/energy_now, which don't exist on
; every machine (this Surface has BAT1 and no power_now). The script derives watts
; from whichever sysfs attributes are actually present.
exec = ~/.local/bin/polybar-powerdraw
interval = 3
format-prefix = "⚡ "
format-prefix-foreground = ${colors.secondary}

[module/battery]
type = internal/battery
{{- /* Detect the real device names at apply time. This tablet is BAT1/ACAD;
       older machines were BAT0/AC. Hardcoding either one breaks the other. */}}
{{- $bat := output "sh" "-c" "ls /sys/class/power_supply/ 2>/dev/null | grep -m1 '^BAT' || echo BAT0" | trim }}
{{- $adp := output "sh" "-c" "ls /sys/class/power_supply/ 2>/dev/null | grep -m1 -E '^(ACAD|AC|ADP)' || echo AC" | trim }}
battery = {{ $bat }}
adapter = {{ $adp }}
full-at = 98

format-charging = <label-charging>
format-discharging = <label-discharging>
format-full = <label-full>

label-charging = 🔌 %percentage%%
label-discharging = 🔋 %percentage%%
label-full = ✅ %percentage%%

[settings]
; Disabled - our autorandr postswitch hook handles polybar restarts
screenchange-reload = false
pseudo-transparency = false
