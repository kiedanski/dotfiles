# ghostty.
#
# NOTE: ghostty reads $XDG_CONFIG_HOME/ghostty/config — NOT config.ghostty.
# An empty config.ghostty sat here doing nothing, so ghostty ran on pure defaults.

font-family = JetBrainsMono Nerd Font
# Matches kitty's font_size 11. Global scaling comes from Xft.dpi in .Xresources;
# this is the per-terminal size on top of that.
font-size = 11

cursor-style = block
mouse-hide-while-typing = true
window-padding-x = 4
window-padding-y = 2

# No startup/quit animations or confirmation friction.
window-decoration = false
confirm-close-surface = false

shell-integration = detect
copy-on-select = clipboard
scrollback-limit = 10000
