{
  "$schema": "https://opencode.ai/config.json",
  "logLevel": "DEBUG",
   "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
      },
    "fireflies": {
      "type": "remote",
      "url": "https://api.fireflies.ai/mcp",
      "enabled": true
      },
